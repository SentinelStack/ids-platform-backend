#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
VALIDATOR="$REPO_ROOT/scripts/validate-commit-message.sh"

z40="0000000000000000000000000000000000000000"

echo "[pre-push] Validating commit messages..."
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_sha" == "$z40" ]]; then
    continue
  fi

  if [[ "$remote_sha" == "$z40" ]]; then
    range="$local_sha"
  else
    range="${remote_sha}..${local_sha}"
  fi

  while read -r commit_sha; do
    subject="$(git log -1 --pretty=%s "$commit_sha")"
    "$VALIDATOR" --message "$subject"
  done < <(git rev-list "$range")
done

export JAVA_HOME="${JAVA_HOME:-$(/usr/libexec/java_home -v 17)}"
export PATH="$JAVA_HOME/bin:$PATH"

echo "[pre-push] Running SpotBugs, Checkstyle and PMD..."
mvn -q -DskipTests spotbugs:check checkstyle:check pmd:check

echo "[pre-push] Checks passed."
